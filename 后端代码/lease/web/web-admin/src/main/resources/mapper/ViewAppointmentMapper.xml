<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.atguigu.lease.web.admin.mapper.ViewAppointmentMapper">

       <resultMap id="AppointmentVoMap" type="com.atguigu.lease.web.admin.vo.appointment.AppointmentVo" autoMapping="true">
              <id property="id" column="id"/>
              <association property="apartmentInfo" javaType="com.atguigu.lease.model.entity.ApartmentInfo" autoMapping="true">
                     <id property="id" column="apartment_id"/>
                     <result property="name" column="apartment_name"/>
              </association>
              <association property="roomInfo" javaType="com.atguigu.lease.model.entity.RoomInfo" autoMapping="true">
                     <id property="id" column="room_id"/>
                     <result property="roomNumber" column="room_number"/>
              </association>
       </resultMap>
       
    <select id="pageAppointment" resultMap="AppointmentVoMap">
           select va.id,
           va.user_id,
           va.name,
           va.phone,
           va.appointment_time,
           va.additional_info,
           va.appointment_status,
           va.room_id,
           va.guide_type,
           va.guide_id,
           va.create_time,
           ai.id   apartment_id,
           ai.name apartment_name,
           ai.district_id,
           ai.district_name,
           ai.city_id,
           ai.city_name,
           ai.province_id,
           ai.province_name,
           ai.address_detail,
           ai.latitude,
           ai.longitude,
           ri.room_number
           from view_appointment va
           left join
           apartment_info ai
           on va.apartment_id = ai.id and ai.is_deleted=0
           left join
           room_info ri
           on va.room_id = ri.id and ri.is_deleted=0
           <where>
                  va.is_deleted = 0
                  <if test="queryVo.provinceId != null">
                         and ai.province_id = #{queryVo.provinceId}
                  </if>
                  <if test="queryVo.cityId != null">
                         and ai.city_id = #{queryVo.cityId}
                  </if>
                  <if test="queryVo.districtId != null">
                         and ai.district_id = #{queryVo.districtId}
                  </if>
                  <if test="queryVo.apartmentId != null">
                         and va.apartment_id = #{queryVo.apartmentId}
                  </if>
                  <if test="queryVo.name != null and queryVo.name != ''">
                         and va.name like concat('%',#{queryVo.name},'%')
                  </if>
                  <if test="queryVo.phone != null and queryVo.phone != ''">
                         and va.phone like concat('%',#{queryVo.phone},'%')
                  </if>
                  <if test="queryVo.guideType != null">
                         and va.guide_type = #{queryVo.guideType}
                  </if>
           </where>
           <choose>
                  <when test="queryVo.sortField != null and queryVo.sortField != ''">
                         <choose>
                                <when test="queryVo.sortField == 'appointmentTime'">
                                       order by va.appointment_time
                                </when>
                                <when test="queryVo.sortField == 'createTime'">
                                       order by va.create_time
                                </when>
                                <otherwise>
                                       order by va.appointment_time
                                </otherwise>
                         </choose>
                         <choose>
                                <when test="queryVo.sortOrder != null and queryVo.sortOrder == 'asc'">
                                       asc
                                </when>
                                <otherwise>
                                       desc
                                </otherwise>
                         </choose>
                  </when>
                  <otherwise>
                         order by va.appointment_time desc
                  </otherwise>
           </choose>
    </select>

    <select id="selectByGuideType" resultType="com.atguigu.lease.model.entity.ViewAppointment">
        SELECT *
        FROM view_appointment
        WHERE guide_type = #{guideType}
          AND is_deleted = 0
        ORDER BY appointment_time DESC
    </select>

    <select id="selectByGuideId" resultType="com.atguigu.lease.model.entity.ViewAppointment">
        SELECT *
        FROM view_appointment
        WHERE guide_id = #{guideId}
          AND is_deleted = 0
        ORDER BY appointment_time DESC
    </select>

    <select id="selectByGuideTypeAndId" resultType="com.atguigu.lease.model.entity.ViewAppointment">
        SELECT *
        FROM view_appointment
        WHERE guide_type = #{guideType}
          AND guide_id = #{guideId}
          AND is_deleted = 0
        ORDER BY appointment_time DESC
    </select>

    <select id="selectByRoomId" resultType="com.atguigu.lease.model.entity.ViewAppointment">
        SELECT *
        FROM view_appointment
        WHERE room_id = #{roomId}
          AND is_deleted = 0
        ORDER BY appointment_time DESC
    </select>

    <select id="selectOfficialAppointments" resultType="com.atguigu.lease.model.entity.ViewAppointment">
        SELECT *
        FROM view_appointment
        WHERE guide_type = 1
          AND is_deleted = 0
        ORDER BY appointment_time DESC
    </select>

    <select id="selectLandlordAppointments" resultType="com.atguigu.lease.model.entity.ViewAppointment">
        SELECT *
        FROM view_appointment
        WHERE guide_type = 2
          AND guide_id = #{landlordId}
          AND is_deleted = 0
        ORDER BY appointment_time DESC
    </select>

</mapper>
