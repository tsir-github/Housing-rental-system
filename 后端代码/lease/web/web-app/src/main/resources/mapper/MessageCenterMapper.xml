<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.atguigu.lease.web.app.mapper.MessageCenterMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.atguigu.lease.model.entity.MessageCenter">
        <id column="id" property="id" />
        <result column="recipient_id" property="recipientId" />
        <result column="recipient_type" property="recipientType" />
        <result column="message_type" property="messageType" />
        <result column="message_category" property="messageCategory" />
        <result column="title" property="title" />
        <result column="content" property="content" />
        <result column="related_entity_type" property="relatedEntityType" />
        <result column="related_entity_id" property="relatedEntityId" />
        <result column="priority" property="priority" />
        <result column="is_read" property="isRead" />
        <result column="read_time" property="readTime" />
        <result column="need_action" property="needAction" />
        <result column="action_status" property="actionStatus" />
        <result column="action_time" property="actionTime" />
        <result column="extend_info" property="extendInfo" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="is_deleted" property="isDeleted" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, recipient_id, recipient_type, message_type, message_category, title, content,
        related_entity_type, related_entity_id, priority, is_read, read_time, need_action,
        action_status, action_time, extend_info, create_time, update_time, is_deleted
    </sql>

    <!-- 获取用户未读消息数量 -->
    <select id="getUnreadCount" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM message_center
        WHERE recipient_id = #{recipientId}
        AND recipient_type = #{recipientType}
        AND is_read = 0
        AND is_deleted = 0
    </select>

    <!-- 批量标记为已读 -->
    <update id="batchMarkAsRead">
        UPDATE message_center
        SET is_read = 1, read_time = NOW(), update_time = NOW()
        WHERE recipient_id = #{recipientId}
        AND recipient_type = #{recipientType}
        AND is_deleted = 0
        <if test="messageIds != null and messageIds.size() > 0">
            AND id IN
            <foreach collection="messageIds" item="id" open="(" separator="," close=")">
                #{id}
            </foreach>
        </if>
        <if test="messageIds == null or messageIds.size() == 0">
            AND is_read = 0
        </if>
    </update>

    <!-- 获取用户消息列表 -->
    <select id="getUserMessages" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" />
        FROM message_center
        WHERE recipient_id = #{recipientId}
        AND recipient_type = #{recipientType}
        AND is_deleted = 0
        <if test="messageType != null and messageType != ''">
            AND message_type = #{messageType}
        </if>
        <if test="isRead != null">
            AND is_read = #{isRead}
        </if>
        ORDER BY priority ASC, create_time DESC
    </select>

</mapper>